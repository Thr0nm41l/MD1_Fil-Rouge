# =============================================================
# Infrastructure Credentials
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
# =============================================================

# PostgreSQL
POSTGRES_ADMIN_PASSWORD=your_strong_password_here       # postgres superuser password

# Airflow DB
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=your_strong_password_here           # password for the airflow DB user

# PgAdmin
PGADMIN_EMAIL=admin@localhost.io
PGADMIN_PASSWORD=your_strong_password_here

# Airflow
AIRFLOW_FERNET_KEY=your_strong_fernet_key_here  # encrypts connections in the metadata DB — must stay stable across restarts
AIRFLOW_API_KEY=your_strong_api_key_here 

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_strong_password_here
