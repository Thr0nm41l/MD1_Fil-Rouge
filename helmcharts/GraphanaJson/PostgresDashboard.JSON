          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    z.name AS zone,\r\n\r\n    ROUND(\r\n        100.0 * COUNT(*) FILTER (\r\n            WHERE c.fill_rate >= c.fill_threshold_pct * 0.95\r\n        ) / COUNT(*),\r\n        0\r\n    ) AS \"Overflowing\",\r\n\r\n    ROUND(\r\n        100.0 * COUNT(*) FILTER (\r\n            WHERE c.fill_rate >= c.fill_threshold_pct * 0.90\r\n            AND c.fill_rate < c.fill_threshold_pct * 0.95\r\n        ) / COUNT(*),\r\n        0\r\n    ) AS \"Critically filled\",\r\n\r\n    ROUND(\r\n        100.0 * COUNT(*) FILTER (\r\n            WHERE c.fill_rate >= c.fill_threshold_pct * 0.70\r\n              AND c.fill_rate < c.fill_threshold_pct * 0.90\r\n        ) / COUNT(*),\r\n        0\r\n    ) AS \"Close to full\",\r\n\r\n    ROUND(\r\n        100 * COUNT(*) FILTER (\r\n            WHERE c.fill_rate >= c.fill_threshold_pct * 0.25\r\n              AND c.fill_rate < c.fill_threshold_pct * 0.70\r\n        ) / COUNT(*),\r\n        0\r\n    ) AS \"Normal\",\r\n\r\n    ROUND(\r\n        100.0 * COUNT(*) FILTER (\r\n            WHERE c.fill_rate < c.fill_threshold_pct * 0.25\r\n        ) / COUNT(*),\r\n        0\r\n    ) AS \"Empty\"\r\n\r\nFROM containers c\r\nJOIN zones z\r\n    ON z.key_zone = c.zone_id\r\nWHERE c.is_active = true\r\nGROUP BY z.key_zone, z.name\r\nORDER BY z.name;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
