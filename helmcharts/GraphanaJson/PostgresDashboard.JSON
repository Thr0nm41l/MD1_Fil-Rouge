          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    z.name AS zone,\r\n\r\n    ROUND(\r\n        (SUM(ST_Length(r.path::geography)) / 1000.0)::numeric,\r\n        2\r\n    ) AS distance_tournees_km,\r\n\r\n    COUNT(DISTINCT r.key_route) AS nb_tournees,\r\n\r\n    COUNT(DISTINCT rs.container_id) AS conteneurs_planifies,\r\n\r\n    COUNT(*) FILTER (\r\n        WHERE rs.collected = true\r\n    ) AS collectes_effectuees,\r\n\r\n    ROUND(\r\n        (\r\n            100.0 * COUNT(*) FILTER (\r\n                WHERE rs.collected = true\r\n            ) / NULLIF(COUNT(rs.key_step), 0)\r\n        )::numeric,\r\n        1\r\n    ) AS taux_realisation_pct\r\n\r\nFROM routes r\r\nJOIN zones z\r\n    ON z.key_zone = r.zone_id\r\nLEFT JOIN route_steps rs\r\n    ON rs.route_id = r.key_route\r\n\r\nWHERE r.status = 'terminee'\r\n\r\nGROUP BY z.key_zone, z.name\r\n\r\nORDER BY distance_tournees_km DESC\r\n\r\nLIMIT 10;",
          "refId": "A",
